# Copy to .env and adjust if needed. Defaults match docker-compose.
# For scripts run on your HOST machine (not inside containers), use localhost.

# Data source: "generator" (synthetic, always works) or "binance" (real, live)
SOURCE=generator

# Kafka
KAFKA_BOOTSTRAP=localhost:9092
KAFKA_TOPIC=trades

# Data lake (MinIO)
S3_ENDPOINT=http://localhost:9000
S3_KEY=minioadmin
S3_SECRET=minioadmin
LAKE_BUCKET=datalake

# Warehouse (Postgres)
PG_HOST=localhost
PG_PORT=5432
PG_DB=warehouse
PG_USER=dbt
PG_PASSWORD=dbt

# Batch config
BATCH_DAYS=180
